def u256_le_to_be : List Op := [
  .inst (.reversew),
  .inst (.swapw 1),
  .inst (.reversew)
]

def u256_le_to_be_pair : List Op := [
  .inst (.exec "u256_le_to_be"),
  .inst (.swapdw),
  .inst (.exec "u256_le_to_be"),
  .inst (.swapdw)
]

